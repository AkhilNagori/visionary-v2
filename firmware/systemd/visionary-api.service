[Unit]
Description=Visionary local API (FastAPI on :8321)
After=network-online.target visionary.service
Wants=visionary.service

[Service]
Type=simple
WorkingDirectory=/opt/visionary/app
EnvironmentFile=/etc/visionary.env
ExecStart=/usr/bin/python3 -m uvicorn api:app --host 0.0.0.0 --port 8321
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
